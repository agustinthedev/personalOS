// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  subtitle       String
  summary        String
  body           String
  topic          String
  tags           String
  readingMinutes Int
  status         String    @default("DRAFT")
  generatedBy    String
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([topic])
}

model KanbanBoard {
  id         String            @id @default(cuid())
  name       String
  isDefault  Boolean           @default(false)
  columns    KanbanColumn[]
  categories KanbanCategory[]
  tasks      KanbanTask[]
  events     KanbanTaskEvent[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([isDefault])
}

model KanbanColumn {
  id                String               @id @default(cuid())
  boardId           String
  board             KanbanBoard          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name              String
  position          Int
  semanticType      KanbanColumnSemantic @default(CUSTOM)
  countsAsCompleted Boolean              @default(false)
  cardColor         String               @default("#ffffff")
  cardOpacity       Float                @default(0.03)
  wipLimit          Int                  @default(100)
  tasks             KanbanTask[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([boardId, position])
}

model KanbanCategory {
  id        String       @id @default(cuid())
  boardId   String
  board     KanbanBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String
  color     String       @default("#94a3b8")
  isDefault Boolean      @default(false)
  tasks     KanbanTask[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([boardId, name])
}

model KanbanTask {
  id              String                @id @default(cuid())
  boardId         String
  board           KanbanBoard           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  columnId        String?
  column          KanbanColumn?         @relation(fields: [columnId], references: [id], onDelete: SetNull)
  categoryId      String?
  category        KanbanCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  priority        KanbanTaskPriority    @default(MEDIUM)
  dueDate         DateTime?
  position        Int
  archivedAt      DateTime?
  columnChangedAt DateTime              @default(now())
  completedAt     DateTime?
  checklistItems  KanbanChecklistItem[]
  comments        KanbanTaskComment[]
  events          KanbanTaskEvent[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([boardId, archivedAt])
  @@index([boardId, completedAt])
  @@index([columnId, position])
  @@index([categoryId])
  @@index([priority])
  @@index([dueDate])
}

model KanbanChecklistItem {
  id        String     @id @default(cuid())
  taskId    String
  task      KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  completed Boolean    @default(false)
  position  Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([taskId, position])
}

model KanbanTaskComment {
  id        String     @id @default(cuid())
  taskId    String
  task      KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  body      String
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt])
}

model KanbanTaskEvent {
  id           String          @id @default(cuid())
  taskId       String?
  task         KanbanTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  boardId      String
  board        KanbanBoard     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  type         KanbanEventType
  fromColumnId String?
  toColumnId   String?
  metadata     String?
  createdAt    DateTime        @default(now())

  @@index([boardId, createdAt])
  @@index([taskId, createdAt])
  @@index([type, createdAt])
}

enum KanbanColumnSemantic {
  TODO
  ACTIVE
  DONE
  CUSTOM
}

enum KanbanTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum KanbanEventType {
  CREATED
  UPDATED
  MOVED
  COMPLETED
  REOPENED
  ARCHIVED
  RESTORED
  COMMENTED
  CHECKLIST_UPDATED
}

model PortfolioSettings {
  id                    String   @id @default(cuid())
  displayCurrency       Currency @default(USD)
  priceRefreshHours     Int      @default(1)
  snapshotIntervalHours Int      @default(24)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PortfolioAsset {
  id                          String                 @id @default(cuid())
  name                        String
  symbol                      String?
  kind                        PortfolioItemKind
  marketType                  MarketAssetType?
  manualType                  ManualAssetType?
  currency                    Currency
  manualValue                 Decimal?
  quantityHeld                Decimal?               @default(0)
  averageCost                 Decimal?
  costBasis                   Decimal?
  currentUnitPrice            Decimal?
  currentTotalValue           Decimal                @default(0)
  expectedAnnualGrowthPercent Decimal?
  isIncomeProducing           Boolean                @default(false)
  expectedMonthlyIncome       Decimal?
  maturityDate                DateTime?
  priceProvider               PriceProvider          @default(MANUAL)
  autoPriceEnabled            Boolean                @default(false)
  lastPriceUpdatedAt          DateTime?
  accountNote                 String?
  notes                       String?
  archivedAt                  DateTime?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  transactions                PortfolioTransaction[]
  priceSnapshots              AssetPriceSnapshot[]

  @@index([kind])
  @@index([marketType])
  @@index([manualType])
  @@index([symbol])
  @@index([archivedAt])
  @@index([lastPriceUpdatedAt])
}

model PortfolioTransaction {
  id          String                   @id @default(cuid())
  assetId     String
  asset       PortfolioAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type        PortfolioTransactionType
  quantity    Decimal
  unitPrice   Decimal?
  grossAmount Decimal?
  fees        Decimal?                 @default(0)
  currency    Currency
  executedAt  DateTime
  accountNote String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([assetId, executedAt])
  @@index([type])
  @@index([archivedAt])
}

model PortfolioLiability {
  id             String        @id @default(cuid())
  name           String
  type           LiabilityType @default(OTHER)
  currency       Currency
  currentBalance Decimal
  payoffMonths   Int?
  accountNote    String?
  notes          String?
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([archivedAt])
}

model AssetPriceSnapshot {
  id         String         @id @default(cuid())
  assetId    String
  asset      PortfolioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  unitPrice  Decimal
  currency   Currency
  source     String
  capturedAt DateTime       @default(now())

  @@index([assetId, capturedAt])
}

model PortfolioSnapshot {
  id               String         @id @default(cuid())
  totalAssets      Decimal
  totalLiabilities Decimal
  netWorth         Decimal
  currency         Currency
  source           SnapshotSource @default(AUTO)
  note             String?
  capturedAt       DateTime       @default(now())

  @@index([currency, capturedAt])
  @@index([source, capturedAt])
}

model ExchangeRateSnapshot {
  id         String   @id @default(cuid())
  base       Currency
  quote      Currency
  rate       Decimal
  source     String
  capturedAt DateTime @default(now())

  @@index([base, quote, capturedAt])
}

enum Currency {
  USD
  UYU
}

enum PortfolioItemKind {
  MARKET_ASSET
  MANUAL_ASSET
}

enum MarketAssetType {
  STOCK
  ETF
  FUND
  BOND
  CRYPTO
  COMMODITY
}

enum ManualAssetType {
  CASH
  CASH_EQUIVALENT
  REAL_ESTATE
  VEHICLE
  COLLECTIBLE
  OTHER
}

enum LiabilityType {
  LOAN
  CREDIT_CARD
  MORTGAGE
  PERSONAL_DEBT
  OTHER
}

enum PriceProvider {
  MANUAL
  MARKET_API
  FX_API
}

enum PortfolioTransactionType {
  BUY
  SELL
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
}

enum SnapshotSource {
  AUTO
  MANUAL
}
